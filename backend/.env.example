# Copia este archivo a .env y ajusta los valores.

# --- Proveedor de IA ---
# "mock" funciona sin ninguna key (heurística local). "gemini" usa la API real.
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# Necesaria solo si LLM_PROVIDER=gemini y/o EMBEDDING_PROVIDER=gemini.
# Se obtiene en https://aistudio.google.com/apikey
GEMINI_API_KEY=

GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- CORS: orígenes permitidos para el frontend (separados por coma) ---
CORS_ORIGINS=http://localhost:3000
